function mkcd() {
    # shellcheck disable=SC2164
    command mkdir -p "$1" && cd "$1"
}
function mkcdtmp() {
    cd "$(mktemp -d /tmp/tmp.XXXXXXXXXX)" || return
}
function tls() {
  tmux ls -F '#{session_activity}|#{session_name}|#{session_created}|#{session_attached}' \
    | sort -t'|' -k1 -rn \
    | while IFS='|' read act name cre att; do
        printf "%-20s  created: %s  last active: %s  %s\n" \
          "$name" "$(date -d @$cre '+%b %d %H:%M')" "$(date -d @$act '+%b %d %H:%M')" \
          "$([ "$att" = 1 ] && echo '(attached)')"
      done
}
function extract() {
    case "$1" in
        *.tar.gz|*.tgz)  tar xzf "$1";;
        *.tar.bz2|*.tbz) tar xjf "$1";;
        *.tar.xz|*.txz)  tar xJf "$1";;
        *.tar)            tar xf "$1";;
        *.zip)            unzip "$1";;
        *.gz)             gunzip "$1";;
        *.bz2)            bunzip2 "$1";;
        *.xz)             unxz "$1";;
        *.7z)             7z x "$1";;
        *)                echo "unknown: $1";;
    esac
}
function bkup() {
    local d=false
    [[ "$1" == "-d" ]] && d=true && shift
    local t="${1%/}"
    local s=$($d && date +".%m-%d_%H-%S").bkup
    # TODO verify- bump depth?
    if [ ! -e "$t$s" ]; then
        local old=$(realpath -m "$t")
        mv -iv "$t" "$t$s"
        local new=$(realpath -m "$t$s")
        fd -t l -d 2 . "$(dirname "$old")" | while read -r lnk; do
            local tgt=$(realpath -m "$(dirname "$lnk")/$(readlink "$lnk")")
            [[ "$tgt" == "$old"* ]] && ln -sfn "${new}${tgt#"$old"}" "$lnk"
        done
    else
        echo "$t$s already exists"
    fi
}
function nixos-switch () {
    git -C /etc/nixos add -A
    sudo nixos-rebuild switch --flake /etc/nixos && \
    git -C /etc/nixos commit -m "nixos: $(date '+%Y-%m-%d %H:%M')" && \
    git -C /etc/nixos push
}

