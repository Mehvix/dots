alias dirs="eza --list-dirs"
alias t="eza --tree" #  --git-ignore --no-git # <- git ignore hangs ..
alias t2="eza --tree --level=2 -l"
alias t3="eza --tree --level=3 -l"
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}

