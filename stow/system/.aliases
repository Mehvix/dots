function timesh () {
    shell=${1-$SHELL};
    for i in $(seq 1 10);
    do {
        env time -f "%e" "$shell" -i -c exit 2>&1 > /dev/null
    } 2>&1 | grep -v bleopt | grep -v exit;
    done
}

