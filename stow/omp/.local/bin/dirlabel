#!/usr/bin/env bash
# Manage per-directory labels (inherited by descendants) for the OMP prompt.
# Storage: $XDG_CONFIG_HOME/dirlabels, one "PATH<TAB>LABEL<TAB>COLOR_INDEX" per line.
set -euo pipefail

file="${XDG_CONFIG_HOME:-$HOME/.config}/dirlabels"
mkdir -p "$(dirname "$file")"
: > /dev/null; [[ -f "$file" ]] || : > "$file"

arg="${1:-env}"
case "$arg" in env|set|clear|list|help|-h|--help) cmd="$arg"; shift || true ;; *) echo "unknown command: $arg" >&2; exit 2 ;; esac

_colors=(
  fcda43
  7ed644
  159c76
  7be5e5
  61afef
  c678dd
  bc3387
  c25656
)

_ansi() { # hex -> colored text
  local hex="$1" txt="$2"
  printf '\033[38;2;%d;%d;%dm%s\033[0m' "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}" "$txt"
}

_strip() {
  local d="$1" tmp; tmp=$(mktemp)
  awk -F'\t' -v d="$d" '$1 != d' "$file" > "$tmp"
  mv "$tmp" "$file"
}

_next_color() { # pick first unused color index, fallback to least recent
  local -A used
  while IFS=$'\t' read -r _ _ ci; do
    [[ -n "$ci" ]] && used[$ci]=1
  done < "$file"
  for (( i=0; i<${#_colors[@]}; i++ )); do
    [[ -z "${used[$i]:-}" ]] && echo "$i" && return
  done
  echo 0
}

case "$cmd" in
  set)
    label="${1:?usage: dirlabel set <label>}"
    dir="$(pwd -P)"
    # check if cwd inherits from a parent (no exact match)
    parent_dir="" parent_label=""
    while IFS=$'\t' read -r d l ci; do
      [[ -z "$d" || "$d" == "$dir" ]] && continue
      if [[ "$dir" == "$d"/* ]] && (( ${#d} > ${#parent_dir} )); then
        parent_dir="$d" parent_label="$l" parent_ci="$ci"
      fi
    done < "$file"
    if [[ -n "$parent_dir" ]] && ! grep -q "^${dir}"$'\t' "$file"; then
      printf 'Inherited label "%s" from %s\nChange parent label? [y/N] ' "$parent_label" "$parent_dir" >&2
      read -r ans </dev/tty
      if [[ "$ans" == [yY]* ]]; then
        _strip "$parent_dir"
        printf '%s\t%s\t%s\n' "$parent_dir" "$label" "$parent_ci" >> "$file"
        exit 0
      fi
    fi
    _strip "$dir"
    ci=$(_next_color)
    printf '%s\t%s\t%s\n' "$dir" "$label" "$ci" >> "$file"
    ;;
  clear)
    _strip "$(cd "${1:-.}" && pwd -P)"
    ;;
  env)
    # eval "$(dirlabel env)" — or just "eval $(dirlabel)"
    cur="$(pwd -P)"; best=""; best_len=0; best_ci=0
    while IFS=$'\t' read -r dir label ci; do
      [[ -z "$dir" ]] && continue
      if [[ "$cur" == "$dir" || "$cur" == "$dir"/* ]] && (( ${#dir} > best_len )); then
        best="$label"; best_len=${#dir}; best_ci="${ci:-0}"
      fi
    done < "$file"
    printf 'export DIR_LABEL=%q DIR_LABEL_COLOR=#%s\n' "$best" "${_colors[$best_ci]}"
    ;;
  list)
    while IFS=$'\t' read -r dir label ci; do
      [[ -z "$dir" ]] && continue
      _ansi "${_colors[${ci:-0}]}" "$(printf '%-12s' "$label")"
      printf '  %s\n' "$dir"
    done < "$file"
    ;;
  help|-h|--help)
    cat <<'EOF'
dirlabel — per-directory labels for the OMP prompt

  dirlabel set <label>    set label for current directory
  dirlabel clear [path]   remove label (default: cwd)
  dirlabel list           show all entries with colors
  dirlabel env            export DIR_LABEL & DIR_LABEL_COLOR (default)
  dirlabel help           this message

Prompt integration:  eval "$(dirlabel)"
EOF
    ;;
  *)
    echo "usage: dirlabel {set|clear|list|env|help}" >&2; exit 2 ;;
esac
