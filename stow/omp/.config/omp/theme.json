{
  "upgrade": {
    "notice": true,
    "interval": "168h",
    "auto": false,
    "source": "cdn"
  },
  "transient_prompt": {
    "background": "transparent",
    "foreground": "#abb2bf",
    "template": "<#61afef>\u276f</> "
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#3e4452",
          "foreground": "#61afef",
          "foreground_templates": [
            "{{ if .Env.OMP_HOST_COLOR }}{{ .Env.OMP_HOST_COLOR }}{{ end }}"
          ],
          "style": "plain",
          "template": " {{ if .WSL }}WSL at {{ end }}{{ if .Env.OMP_HOST_ICON }}{{ .Env.OMP_HOST_ICON }}{{ else }}{{.Icon}}{{ end }} \ue0b1",
          "type": "os"
        },
        {
          "background": "#3e4452",
          "foreground": "#61afef",
          "foreground_templates": [
            "{{ if .Env.OMP_HOST_COLOR }}{{ .Env.OMP_HOST_COLOR }}{{ end }}"
          ],
          "style": "plain",
          "template": " \uf0e7 ",
          "type": "root"
        },
        {
          "background": "#3e4452",
          "foreground": "#61afef",
          "foreground_templates": [
            "{{ if .Env.OMP_HOST_COLOR }}{{ .Env.OMP_HOST_COLOR }}{{ end }}"
          ],
          "options": {
            "style": "full"
          },
          "style": "plain",
          "template": " {{ $p := .Path }}{{ range $s := splitList \":\" .Env.OMP_PATH_STRIP }}{{ if $s }}{{ $p = trimPrefix $s $p }}{{ end }}{{ end }}{{ $p }} ",
          "type": "path"
        },
        {
          "background": "#3e4452",
          "foreground": "#61afef",
          "foreground_templates": [
            "{{ if .Env.OMP_HOST_COLOR }}{{ .Env.OMP_HOST_COLOR }}{{ end }}"
          ],
          "style": "plain",
          "template": "\ue0b1 ",
          "type": "text"
        },
        {
          "background": "#3e4452",
          "foreground": "#98c379",
          "style": "plain",
          "template": "{{ .HEAD }} ",
          "type": "git",
          "options": {
            "branch_icon": "\ue725 "
          }
        },
        {
          "background": "transparent",
          "foreground": "#3e4452",
          "style": "plain",
          "template": "\ue0b0",
          "type": "text"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "#3e4452",
          "foreground": "#e5c07b",
          "style": "diamond",
          "leading_diamond": "\ue0b2",
          "options": {
            "time_format": "15:04:05"
          },
          "template": " {{ .CurrentDate | date .Format }} ",
          "type": "time"
        },
        {
          "background": "#3e4452",
          "foreground": "#c678dd",
          "style": "plain",
          "template": "{{ if .Env.DIR_LABEL }}\ue0b3 {{ .Env.DIR_LABEL }} {{ end }}",
          "type": "text"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#98c379",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#e06c75{{ end }}"
          ],
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "\u276f ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 4
}